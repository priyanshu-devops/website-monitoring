{
  "name": "domain-monitor",
  "version": "1.0.0",
  "description": "Enterprise-grade domain monitoring system — Google Sheets + GitHub Actions",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/src/index.js",
    "monitor": "ts-node --project tsconfig.json src/index.ts",
    "dev": "ts-node --project tsconfig.json src/index.ts",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "googleapis": "^140.0.1",
    "playwright": "^1.44.0",
    "sharp": "^0.33.4",
    "whoiser": "^1.17.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "rimraf": "^5.0.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
