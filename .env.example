# ─────────────────────────────────────────────────────────────
#  DOMAIN MONITOR — Environment Variables Template
#  Copy this file to .env and fill in your values.
#  Never commit your actual .env file!
# ─────────────────────────────────────────────────────────────

# ── Google Sheets ─────────────────────────────────────────────
# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# The tab name in your Google Sheet (default: Sheet1)
SHEET_NAME=Sheet1

# ── Google Service Account Credentials ───────────────────────
# Paste the entire service-account JSON as a single line,
# OR base64-encode it: base64 -w0 service-account.json
GOOGLE_CREDENTIALS={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"monitor@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/monitor%40your-project.iam.gserviceaccount.com"}

# ── GitHub (for screenshot storage) ──────────────────────────
# GitHub username or organization name
GITHUB_OWNER=your_github_username

# Repository name (this repo)
GITHUB_REPO=domain-monitor

# Branch to store screenshots (must exist)
GITHUB_BRANCH=main

# Personal Access Token (only needed for LOCAL development)
# In GitHub Actions, the built-in GITHUB_TOKEN is used automatically.
# Scopes needed: repo (for private repos) or public_repo (for public repos)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Performance Settings ──────────────────────────────────────
# Max concurrent domain checks (recommended: 10 for Actions, 5 locally)
CONCURRENCY_LIMIT=10

# Per-domain HTTP timeout in milliseconds
REQUEST_TIMEOUT=10000

# Number of retry attempts for failed requests
RETRY_ATTEMPTS=2

# ── Features ──────────────────────────────────────────────────
# Set to false to skip screenshots (faster, saves Actions minutes)
ENABLE_SCREENSHOTS=true
